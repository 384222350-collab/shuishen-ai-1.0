# 默认环境变量示例（不要在此填写真实密钥并提交）
# 复制本文件为 .env 并填写你的值：

OPENAI_BASE_URL=https://api.example.com
OPENAI_API_KEY=
OPENAI_MODEL=deepseek-v4-flash

# Bot 配置
BOT_PLATFORM=web
BOT_NAME=Shuishen
BOT_OWNER_NAME=bigd
BOT_REPLY_GROUPS=true
BOT_GROUP_MENTION_ONLY=true
BOT_MAX_HISTORY=12

# Web 控制台
WEB_LISTEN_HOST=127.0.0.1
WEB_LISTEN_PORT=5173
WEB_ENABLE_QQ_BOT=false
WEB_ENABLE_WECHAT_BOT=true

# 图片人格（如中转模型支持视觉）
ENABLE_IMAGE_PERSONA=false

# QQ OneBot 示例（如使用 QQ）
QQ_LISTEN_HOST=127.0.0.1
QQ_LISTEN_PORT=3001
QQ_ONEBOT_BASE_URL=http://127.0.0.1:3000
QQ_ONEBOT_ACCESS_TOKEN=
